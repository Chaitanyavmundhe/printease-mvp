{
  "name": "printease-backend",
  "version": "1.0.0",
  "description": "PrintEase backend API for QR based smart printing platform",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:setup": "node src/db/setup.js",
    "db:schema": "node src/db/setup.js --schema-only",
    "db:seed": "node src/db/setup.js --seed-only"
  },
  "keywords": [
    "printing",
    "express",
    "supabase",
    "render",
    "printease"
  ],
  "author": "PrintEase Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0",
    "uuid": "^11.0.5"
  }
}
