{
  "name": "printease-backend",
  "version": "1.0.0",
  "description": "PrintEase backend API for QR based smart printing platform",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:setup": "node src/db/setup.js",
    "db:schema": "node src/db/setup.js --schema-only",
    "db:seed": "node src/db/setup.js --seed-only"
  },
  "keywords": [
    "printing",
    "express",
    "supabase",
    "render",
    "printease"
  ],
  "author": "PrintEase Team",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0"
  }
}
