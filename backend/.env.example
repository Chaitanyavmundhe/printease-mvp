PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change_this_secret_before_production

# Local PostgreSQL
# Ubuntu local PostgreSQL usually works best through the Unix socket after you create
# a matching PostgreSQL role for your Linux user.
PGHOST=/var/run/postgresql
PGPORT=5432
PGDATABASE=printease
# PGUSER=postgres
# PGPASSWORD=postgres
# Or use one connection string instead:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/printease
DB_SSL=false

# Future Supabase integration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Future Razorpay integration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
